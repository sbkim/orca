# Fastlane Environment Variables (TEMPLATE)
# Copy to fastlane/.env (gitignored) and fill in real values.

# Firebase App Distribution (SPEC-FCM-001 device-test distribution + beta)
# Service-account JSON with "Firebase App Distribution Admin" role.
# Console > Project settings > Service accounts > Generate new private key.
FIREBASE_SERVICE_CREDENTIALS_FILE=/absolute/path/to/firebase-service-account.json
FIREBASE_ANDROID_APP_ID=1:58118591799:android:ec70a3c26e03841db836b2
FIREBASE_IOS_APP_ID=1:58118591799:ios:be34ee69aad8322fb836b2

# Tester groups (create in Console > App Distribution > Groups; comma-separated)
FIREBASE_ANDROID_GROUPS=
FIREBASE_IOS_GROUPS=

# Apple — team ID for iOS automatic signing (firebase:ios lane).
# Get it: Apple Developer > Membership Details > Team ID (10-char).
APPLE_TEAM_ID=

# ASC API key — ONLY for the TestFlight `release` lane (NOT firebase:ios, which
# uses Xcode automatic signing). Leave commented if you're not using TestFlight.
# ASC_KEY_ID=
# ASC_ISSUER_ID=
# ASC_API_KEY_P8=
